Workspace/

# Obsoleto: auditorías van en Workspace/audit/
audit-output/

# Repos externos legacy (migrados a Workspace/*/repos/)
ciencuadras-repos/

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Kiro: MCP config local (cada usuario configura sus propios MCPs/tokens)
.kiro/settings/mcp.json

# Credentials vault local (cada usuario llena con sus propias credenciales)
Workspace/config/credentials.json

# Cursor + Miniverse: estado efímero (legacy)
.cursor/

# POCs experimentales (no suben al repo principal)
poc-agentescloud/
squad-agentes-adk/

# Scripts con credenciales particulares (usar el template)
scripts/powerbi-connect.sh

# Screenshots temporales en raíz (deben ir a Workspace/{plataforma}/evidencias/)
/*.png

