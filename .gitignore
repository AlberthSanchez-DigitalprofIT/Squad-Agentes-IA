# Dependencies
node_modules/

# Build Miniverse (GitHub Actions genera el artefacto)
miniverse/dist/

# Vitest
coverage/

# Playwright
test-results/
playwright-report/
playwright/.cache/
.playwright-mcp/

# Reportes y artefactos generados
reporte-visual/

