{
  "name": "cloud-infra",
  "description": "Cloud Infra — Auditor de infraestructura AWS. Costos, seguridad, inventario de recursos, optimización y compliance de tagging.",
  "prompt": "file://../steering/agent-cloud-infra.md",
  "model": "claude-sonnet-4",
  "tools": [
    "read",
    "write",
    "shell",
    "@aws-api",
    "@atlassian"
  ],
  "allowedTools": [
    "read",
    "@aws-api/call_aws",
    "@atlassian/getJiraIssue",
    "@atlassian/searchJiraIssuesUsingJql",
    "@atlassian/getAccessibleAtlassianResources",
    "@atlassian/getJiraProjectIssueTypesMetadata",
    "@atlassian/getJiraIssueTypeMetaWithFields"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "Workspace/**/reports/**",
        "Workspace/plans/**"
      ]
    }
  },
  "resources": [
    "file://../steering/agent-cloud-infra.md",
    "file://../steering/05-jira-writing-guidelines.md",
    "file://../steering/06-platform-context.md",
    "file://../../Workspace/config/platforms.json",
    "file://../../.iarules/rules-infrastructure.md",
    "file://../../.iarules/rules-security.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "echo 'Cloud Infra activado — Auditoría de infraestructura AWS'"
      }
    ],
    "preToolUse": [
      {
        "matcher": "@atlassian/createJiraIssue",
        "command": "echo 'Escritura en Jira — Verificar metadata de campos y que Creado con IA va en descripción.' >&2; exit 0"
      }
    ]
  },
  "includeMcpJson": false,
  "mcpServers": {
    "aws-api": {
      "command": "uvx",
      "args": ["awslabs.aws-api-mcp-server@latest"],
      "env": {
        "AWS_REGION": "${AWS_REGION:-us-east-1}"
      }
    },
    "atlassian": {
      "command": "npx",
      "args": ["-y", "mcp-remote@latest", "https://mcp.atlassian.com/v1/mcp"]
    }
  },
  "keyboardShortcut": "ctrl+6",
  "welcomeMessage": "Cloud Infra activo. ¿Qué auditoría de infraestructura AWS necesitas? (costos, seguridad, inventario, optimización, tagging)"
}
